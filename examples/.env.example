# Outlap local environment
APP_ENV=development
APP_AUTH_MODE=local_only
APP_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DUCKDB_PATH=./data/raceweek.duckdb
RWS_DUCKDB_PATH=./data/raceweek.duckdb

# Fantasy connector: optional, read-only. Structured market import and team selection work without this.
FANTASY_API_BASE_URL=https://fantasy-api.formula1.com/partner_games/f1
# Optional. Leave blank to use the selected/current UTC season at runtime.
FANTASY_GAME_VERSION=
FANTASY_SESSION_TOKEN=

# Race/session data
OPENF1_BASE_URL=https://api.openf1.org/v1
JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1
FASTF1_CACHE_PATH=./data/fastf1-cache

# AI providers. Use only providers you configure.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=

# Local/default OpenAI-compatible endpoints
OLLAMA_BASE_URL=http://localhost:11434/v1
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_API_KEY=

# Optional app behavior
ENABLE_LIVE_CONNECTOR_TESTS=false
LOG_LEVEL=INFO
