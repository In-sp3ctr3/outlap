{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raceweek-strategist.local/schemas/news_item.schema.json",
  "title": "NewsItem",
  "type": "object",
  "required": [
    "newsId",
    "sourceName",
    "title",
    "url",
    "retrievedAt"
  ],
  "properties": {
    "newsId": {
      "type": "string"
    },
    "sourceName": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "publishedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "retrievedAt": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "riskFlags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "licenseNote": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
